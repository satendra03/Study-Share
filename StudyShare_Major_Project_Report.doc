  <h2>4.3 Key Code Snippets</h2>

  <h3>4.3.1 Firebase Token Verification Middleware</h3>
  <p><em>File: backend/src/middlewares/verifyFirebaseToken.ts</em></p>
  <div class="code">import { Request, Response, NextFunction } from "express";
import { firebaseAdmin } from "../config/firebase.config";

export const verifyFirebaseToken = async (
  req: Request, res: Response, next: NextFunction
) => {
  const authHeader = req.headers.authorization;
  if (!authHeader?.startsWith("Bearer ")) {
    return res.status(401).json({ message: "Unauthorized: No token provided" });
  }
  const token = authHeader.split("Bearer ")[1];
  try {
    const decoded = await firebaseAdmin.auth().verifyIdToken(token);
    req.firebaseUid = decoded.uid;
    next();
  } catch {
    return res.status(401).json({ message: "Unauthorized: Invalid token" });
  }
};</div>

  <h3>4.3.2 Material Upload Controller</h3>
  <p><em>File: backend/src/modules/materials/materials.controller.ts (excerpt)</em></p>
  <div class="code">export const uploadMaterial = async (req: Request, res: Response) => {
  const file = req.file;
  if (!file) return res.status(400).json(new ApiError(400, "No file provided"));

  // Upload to Cloudinary
  const result = await cloudinary.uploader.upload(file.path, {
    resource_type: "raw",
    folder: "study-share/materials",
  });

  // Create MongoDB record
  const material = await Material.create({
    ...req.body,
    fileUrl: result.secure_url,
    cloudinaryPublicId: result.public_id,
    uploaderId: req.firebaseUid,
    status: "processing",
  });

  // Enqueue background job
  await materialQueue.add("process-material", { materialId: material._id });

  return res.status(201).json(
    new ApiResponse(201, material, "Material uploaded successfully")
  );
};</div>

  <h3>4.3.3 AI Document Chat Controller</h3>
  <p><em>File: backend/src/modules/materials/materials.controller.ts (excerpt)</em></p>
  <div class="code">export const chatWithMaterial = async (req: Request, res: Response) => {
  const { id } = req.params;
  const { message, history, pageNumber } = req.body;

  const material = await Material.findById(id);
  if (!material) return res.status(404).json(new ApiError(404, "Not found"));

  // Get relevant page context
  const page = material.pages?.find(p => p.pageNumber === pageNumber);
  const context = page?.rawText || material.pages?.[0]?.rawText || "";

  // Build prompt with context
  const systemPrompt = `You are an academic AI assistant. Answer based on the
  document context provided. If the answer is not in the context, say so clearly.

  Document Context:
  ${context}`;

  const response = await genAI.models.generateContent({
    model: "gemini-2.0-flash",
    contents: [
      { role: "user", parts: [{ text: systemPrompt }] },
      ...history.map(m => ({ role: m.role, parts: [{ text: m.content }] })),
      { role: "user", parts: [{ text: message }] }
    ]
  });

  return res.json(
    new ApiResponse(200, { reply: response.text }, "Reply generated")
  );
};</div>

  <h3>4.3.4 BullMQ Worker – Material Processing</h3>
  <p><em>File: backend/src/infrastructure/queue/worker.ts (excerpt)</em></p>
  <div class="code">const worker = new Worker("material-processing", async (job) => {
  const { materialId } = job.data;
  const material = await Material.findById(materialId);
  if (!material) throw new Error("Material not found");

  // Step 1: OCR
  const pages = await extractTextFromPDF(material.fileUrl);

  // Step 2: Generate embeddings and index to Pinecone
  for (const page of pages) {
    const embedding = await generateEmbedding(page.rawText);
    await pineconeIndex.upsert([{
      id: `${materialId}_page_${page.pageNumber}`,
      values: embedding,
      metadata: { materialId, pageNumber: page.pageNumber }
    }]);
  }

  // Step 3: Update MongoDB
  await Material.findByIdAndUpdate(materialId, {
    pages,
    status: "done"
  });
}, { connection: redisConnection, concurrency: 5 });</div>

  <h3>4.3.5 Frontend – PDF Viewer with Responsive Width</h3>
  <p><em>File: frontend/app/(protected)/materials/[id]/page.tsx (excerpt)</em></p>
  <div class="code">// ResizeObserver ensures correct width on mobile without overflow
useEffect(() => {
  const el = pdfViewerRef.current;
  if (!el) return;
  const measure = () => setPageWidth(Math.min(el.clientWidth - 16, 900));
  measure();
  const ro = new ResizeObserver(measure);
  ro.observe(el);
  return () => ro.disconnect();
}, [blobUrl]);

// PDF rendered with dynamic width — no horizontal overflow on mobile
&lt;Page
  pageNumber={pageNumber}
  renderTextLayer={true}
  renderAnnotationLayer={true}
  width={pageWidth}
/&gt;</div>

  <h3>4.3.6 Zustand Auth Store</h3>
  <p><em>File: frontend/store/authStore.ts (excerpt)</em></p>
  <div class="code">export const useAuthStore = create&lt;AuthState&gt;((set) => ({
  firebaseUser: null,
  appUser: null,
  loading: true,
  profileLoaded: false,
  backendError: false,

  signInWithGoogle: async () => {
    const provider = new GoogleAuthProvider();
    const result = await signInWithPopup(auth, provider);
    const token = await result.user.getIdToken();
    const res = await api.post("/auth/signin", {}, {
      headers: { Authorization: `Bearer ${token}` }
    });
    set({ appUser: res.data.data, profileLoaded: true });
  },

  setAppUser: (user) => set({ appUser: user }),
}));</div>
