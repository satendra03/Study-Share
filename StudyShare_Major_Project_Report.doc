    <tr><td>TC-AI02</td><td>Chat With Unprocessed Material</td><td>Question on material with status: "processing"</td><td>UI shows "Processing" badge; chat input disabled</td><td>Pass</td></tr>
    <tr><td>TC-AI03</td><td>General Chatbot Session Creation</td><td>POST /api/chatbot/sessions</td><td>Session created; session ID returned</td><td>Pass</td></tr>
    <tr><td>TC-AI04</td><td>Chatbot Conversation History</td><td>Multiple messages in a session</td><td>Each response considers prior conversation context</td><td>Pass</td></tr>
    <tr><td>TC-AI05</td><td>Delete Chat Session</td><td>DELETE /api/chatbot/sessions/:id</td><td>Session and all messages deleted from Firestore</td><td>Pass</td></tr>
    <tr><td>TC-AI06</td><td>Code Execution – Valid Python</td><td>print("Hello, World!") in Python</td><td>stdout: "Hello, World!" returned</td><td>Pass</td></tr>
    <tr><td>TC-AI07</td><td>Code Execution – Runtime Error</td><td>Division by zero in JavaScript</td><td>stderr with error message returned; no crash</td><td>Pass</td></tr>
  </table>

